                    car.hasArrived = false;
                    car.remainingTravelTime = TF_CAP_SECONDS;
                    cars.push(car);
                }

                nextCarNumber = cars.length + 1;
                cumulativeSpawned = cars.length;

                endlessInflowSchedule = buildEndlessInflowSchedule(Tmax);

                recomputeTravelTimesByForecast();
                snapshotTravelTimeField();
                snapshotDensityField();
            }

            resetSimulation();
