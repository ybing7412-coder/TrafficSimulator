            }

            restartBtn.addEventListener("click", () => {
                runSimulation();
                frameIndex = 0;
                accumulated = 0;
                lastTimestamp = null;
            });

            let frameIndex = 0;
            let lastTimestamp = null;
            let accumulated = 0;

            function loop(timestamp) {
                if (lastTimestamp === null) {
                    lastTimestamp = timestamp;
                }
                const elapsed = Math.max((timestamp - lastTimestamp) / 1000, 0);
                lastTimestamp = timestamp;
                const speed = parseFloat(speedSlider.value);
                accumulated += elapsed * speed;

                while (accumulated >= dt && frameIndex < Nt) {
                    frameIndex += 1;
                    accumulated -= dt;
                }

                render(frameIndex);
                requestAnimationFrame(loop);
            }

            requestAnimationFrame(loop);
        </script>
