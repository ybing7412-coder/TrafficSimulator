            function drawDensityLineComparison() {
                drawLineComparisonPlot(
                    densityLineCompareCtx, densityLineCompareCanvas,
                    "Density vs Position (Micro vs Macro)", "veh/m", DENSITY_SCALE_MIN, 0.1,
