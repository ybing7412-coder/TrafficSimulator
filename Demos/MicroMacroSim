                    (xM) => displayDensity(directMacroFieldAt(directMacroRho, xM)),
                    (xM) => displayDensity(RHO_F(t, xM, "bot")),
                    (xM) => displayDensity(directMacroFieldAt(directMacroRho, Math.max(0, DIRECT_MACRO_LX - xM)))
                );
