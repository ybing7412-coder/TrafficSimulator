                densityCtx.strokeRect(0, densityRoadYTop - laneHeight / 2, densityCanvas.width, laneHeight * 2 + stripeHeight);
                densityCtx.fillStyle = "#f0f0f0";
                densityCtx.font = "15px Arial"; densityCtx.textAlign = "left"; densityCtx.textBaseline = "top";
