                directMacroDensityCtx.fillText("Direct Macro Density (ARZ)", 14, 8);
            }

            function drawDirectMacroDensityAndScale() {
                const yTop = densityRoadYTop - laneHeight / 2;
                const yBot = densityRoadYBot - laneHeight / 2;
                const stripPx = DENSITY_RENDER_STRIP_PX;
                const rhoTop = [], rhoBot = [];

                for (let xPx = 0; xPx < directMacroDensityCanvas.width; xPx += stripPx) {
