            function drawTravelTimeLineComparison() {
                drawLineComparisonPlot(
                    travelTimeLineCompareCtx, travelTimeLineCompareCanvas,
                    "Travel Time vs Position (Micro vs Macro)", "T (s)",
                    TF_COLOR_SCALE_MIN, TF_COLOR_SCALE_MAX,
                    (xM) => connectedMicroTravelTime(t, xM, "top"),
                    (xM) => connectedDirectMacroTravelTime(xM, "top"),
                    (xM) => connectedMicroTravelTime(t, xM, "bot"),
                    (xM) => connectedDirectMacroTravelTime(xM, "bot")
                );
            }

            // ---------- Initial micro population ----------
            let initialPositions = buildInitialPositions();
            let initialSpeeds = buildEquilibriumInitialSpeeds(initialPositions);

            let cars = initialPositions.map((xPos, i) =>
                new Car(i + 1, xPos, hslColor(i, initialPositions.length), initialSpeeds[i], 0)
            );

            let nextCarNumber = cars.length + 1;
            let cumulativeArrived = 0;
            let cumulativeSpawned = cars.length;
            let endlessScheduleIndex = 0;
            let endlessPendingCars = [];

            let t = 0;
            let stepIndex = 0;
            let paused = false;
            let lastTimestamp = null;
            let accumulatedRealTime = 0;

            // ---------- Eulerian distance metric ----------
            let e_d = 0;

            function computeTimestepDensityGapSq() {
                const kdeGrids = computeMicroKdeGrids();
                let sumSq = 0;

                for (let i = 0; i < KDE_NX; i++) {
                    // Top lane: macro cell i covers [0,L], KDE top cell i covers [0,L]. ✓
                    const diffTop = directMacroRho[i] - kdeGrids.top[i];
                    sumSq += diffTop * diffTop;

                    // Bottom lane: in wrap mode macro covers [0,2L] so bottom lane is
                    // cells [NX-1..NX/2] (reversed). KDE bot cell i covers screen [0,L].
                    // Screen x=0 → ring 2L → macro cell NX-1; screen x=L → macro cell NX/2.
                    const macroIdxBot = wraparoundEnabled ? (DIRECT_MACRO_NX - 1 - i) : i;
                    const diffBot = directMacroRho[macroIdxBot] - kdeGrids.bot[i];
                    sumSq += diffBot * diffBot;
                }
                return sumSq;
            }

            // ---------- Lagrangian distance metric ----------
            let l_d = 0;

            // Advance a position by one DT using the current macro velocity field.
            // xRing is in ring space; returns advanced position in ring space.
            function macroAdvanceOne(xRing) {
                // In wrap mode DIRECT_MACRO_LX = 2L = RING_LENGTH_M so xRing maps
                // directly. In open mode DIRECT_MACRO_LX = L = ROAD_LENGTH_M.
                const xMac = clamp(xRing, 0, DIRECT_MACRO_LX - 1e-9);
                const v = directMacroFieldAt(directMacroU, xMac);
                let xNew = xRing + v * DT;
                if (wraparoundEnabled) {
                    xNew = ((xNew % RING_LENGTH_M) + RING_LENGTH_M) % RING_LENGTH_M;
                }
                return xNew;
            }

            // Given pre-step car positions (Map: number -> x) and the macro-advanced
            // versions of those positions (Map: number -> x), compare to current car
            // positions and return sum of squared differences.
            function computeOneStepLagrangianGapSq(prePositions, macroAdvanced) {
                let sumSq = 0;
                let nCars = 0;
                for (const car of cars) {
                    if (!macroAdvanced.has(car.number)) continue;
                    let diff = car.x - macroAdvanced.get(car.number);
                    if (wraparoundEnabled) {
                        const hl = RING_LENGTH_M / 2;
                        if (diff >  hl) diff -= RING_LENGTH_M;
                        if (diff < -hl) diff += RING_LENGTH_M;
                    }
                    sumSq += diff * diff;
                    nCars++;
                }
                // Normalise by car count so nl_d is comparable across different car counts.
                // Reference is 10 cars.
                const carFactor = nCars > 0 ? 10 / nCars : 1;
                return sumSq * carFactor;
            }

            function applyMode(nextMode) {
                simulationMode = nextMode;
                wraparoundEnabled = simulationMode === MODE_WRAP;
                setupMacroDimensions();
            }

            function resetSimulation() {
                applyMode(simulationMode);
                l = computeDestinationMeters();

                t = 0;
                stepIndex = 0;
                paused = false;
                lastTimestamp = null;
                accumulatedRealTime = 0;

                tfSnapshots.length = 0;
                densitySnapshots.length = 0;
                lastTfLegendRange = { min: 0, max: 1 };
                lastDensityRange = { min: 0, max: 0 };
                e_d = 0;
                l_d = 0;

                cumulativeArrived = 0;
                endlessScheduleIndex = 0;
                endlessPendingCars = [];
                pauseBtn.textContent = "Pause";

                cars.length = 0;
                for (let i = 0; i < initialPositions.length; i++) {
                    const car = new Car(i + 1, initialPositions[i], hslColor(i, initialPositions.length), initialSpeeds[i], 0);
                    car.hasArrived = false;
                    car.remainingTravelTime = TF_CAP_SECONDS;
                    cars.push(car);
                }

                nextCarNumber = cars.length + 1;
                cumulativeSpawned = cars.length;

                endlessInflowSchedule = buildEndlessInflowSchedule(DIRECT_MACRO_TMAX);
                

                recomputeTravelTimesByForecast();
                snapshotTravelTimeField();
                snapshotDensityField();
                buildMacroLookupTables();
                resetDirectMacroFromMicroInitial();
            }

            resetSimulation();
            modeSelect.value = simulationMode;

            modeSelect.addEventListener("change", () => {
                simulationMode = modeSelect.value;
                resetSimulation();
            });

            restartBtn.addEventListener("click", () => {
                V0 = parseFloat(vfSlider.value);
                DIRECT_MACRO_MAX_SPEED = V0;
                const rhoJam = parseFloat(rhoMaxSlider.value);
                MIN_SPACING_M = Math.max(0.5, 1 / rhoJam - CAR_LENGTH_M);
                DIRECT_MACRO_RHO_JAM = 1 / (CAR_LENGTH_M + MIN_SPACING_M);
                initialPositions = buildInitialPositions();
                initialSpeeds = buildEquilibriumInitialSpeeds(initialPositions);
                resetSimulation();
            });

            pauseBtn.addEventListener("click", () => {
                paused = !paused;
                pauseBtn.textContent = paused ? "Resume" : "Pause";
                if (!paused) lastTimestamp = null;
            });

            // ---------- Main step ----------
            function stepSimulation() {
                if (stepIndex >= timeSteps.length - 1) {
                    t = Tmax;
                    paused = true;
                    return;
                }

                // Capture pre-step positions and macro-advance them using directMacroU
                // at the current (old) time — before stepDirectMacro() updates it.
                const lagMacroAdvanced = new Map();
                for (const car of cars) {
                    if (!car.hasArrived) {
                        lagMacroAdvanced.set(car.number, macroAdvanceOne(car.x));
                    }
                }

                stepIndex += 1;
                t = timeSteps[stepIndex];

                if (wraparoundEnabled) {
                    const activeCars = cars.filter((car) => !car.hasArrived);
                    const ordered = [...activeCars].sort((a, b) => a.x - b.x);
                    const spaces = new Map();

                    for (let i = 0; i < ordered.length; i++) {
                        const car = ordered[i];
                        const leader = ordered[(i + 1) % ordered.length];
                        const rawGap = (leader.x - car.x + RING_LENGTH_M) % RING_LENGTH_M;
                        const space = Math.max(rawGap - CAR_LENGTH_M, MIN_SPACING_M);
                        spaces.set(car.number, space);
                    }

                    for (const car of activeCars) {
                        car.updateFollowing(DT, spaces.get(car.number));
                    }

                    if (ordered.length > 1) {
                        const minGap = CAR_LENGTH_M + MIN_SPACING_M;
                        const unwrappedX = new Map();
                        for (const car of ordered) unwrappedX.set(car.number, car.x);

                        for (let pass = 0; pass < 3; pass++) {
                            for (let i = ordered.length - 1; i >= 0; i--) {
                                const car = ordered[i];
                                const leader = i === ordered.length - 1 ? ordered[0] : ordered[i + 1];
                                const leaderX =
                                    i === ordered.length - 1
                                        ? unwrappedX.get(leader.number) + RING_LENGTH_M
                                        : unwrappedX.get(leader.number);
                                const maxAllowedX = leaderX - minGap;
                                if (unwrappedX.get(car.number) > maxAllowedX) {
                                    unwrappedX.set(car.number, maxAllowedX);
                                    car.v = Math.min(car.v, leader.v);
                                }
                            }
                        }

                        for (const car of activeCars) {
                            car.x = unwrappedX.get(car.number);
                        }
                    }

                    for (const car of activeCars) {
                        car.x = ((car.x % RING_LENGTH_M) + RING_LENGTH_M) % RING_LENGTH_M;
                        car.remainingTravelTime = Math.max(car.remainingTravelTime - DT, 0);
                    }

                    if (stepIndex % ETA_REFRESH_INTERVAL_STEPS === 0) {
                        recomputeTravelTimesByForecast();
                    }

                    snapshotTravelTimeField();
                    snapshotDensityField();
                    stepDirectMacro();
                    e_d += computeTimestepDensityGapSq();
                    l_d += computeOneStepLagrangianGapSq(null, lagMacroAdvanced);
                    return;
                }

                const activeCars = cars.filter((car) => !car.hasArrived);
                if (activeCars.length === 0 && simulationMode !== MODE_ENDLESS) {
                    paused = true;
                    return;
                }

                if (activeCars.length > 0) {
                    const ordered = [...activeCars].sort((a, b) => a.x - b.x);
                    const leader = ordered[ordered.length - 1];

                    for (let i = ordered.length - 2; i >= 0; i--) {
                        const car = ordered[i];
                        const carLeader = ordered[i + 1];
                        const rawGap = Math.max(carLeader.x - car.x - CAR_LENGTH_M, 0);
                        const spaceToLeader = Math.max(rawGap, MIN_SPACING_M);
                        car.updateFollowing(DT, spaceToLeader);

                        const maxAllowedX = carLeader.x - CAR_LENGTH_M - MIN_SPACING_M;
                        if (car.x > maxAllowedX) {
                            car.x = maxAllowedX;
                            car.v = Math.min(car.v, carLeader.v);
                        }
                        if (car.x < 0) {
                            car.x = 0;
                            car.v = 0;
                        }
                    }

                    leader.updateLeader(DT);

                    for (let i = ordered.length - 2; i >= 0; i--) {
                        const car = ordered[i];
                        const carLeader = ordered[i + 1];
                        const maxAllowedX = carLeader.x - CAR_LENGTH_M - MIN_SPACING_M;
                        if (car.x > maxAllowedX) {
                            car.x = maxAllowedX;
                            car.v = Math.min(car.v, carLeader.v);
                        }
                        if (car.x < 0) {
                            car.x = 0;
                            car.v = 0;
                        }
                    }

                    for (const car of activeCars) {
                        if (car.x >= l) {
                            car.hasArrived = true;
                            car.v = 0;
                            car.a = 0;
                            car.remainingTravelTime = 0;
                        }
                    }
                }

                for (let i = cars.length - 1; i >= 0; i--) {
                    if (cars[i].hasArrived) {
                        cars.splice(i, 1);
                        cumulativeArrived += 1;
                    }
                }

                if (simulationMode === MODE_ENDLESS) {
                    while (
                        endlessScheduleIndex < endlessInflowSchedule.length &&
                        endlessInflowSchedule[endlessScheduleIndex].time <= t
                    ) {
                        endlessPendingCars.push(endlessInflowSchedule[endlessScheduleIndex]);
                        endlessScheduleIndex += 1;
                    }

                    while (endlessPendingCars.length > 0 && canInsertCarAtUpstream()) {
                        const nextArrival = endlessPendingCars.shift();
                        spawnOneEndlessCar(nextArrival.speed);
                    }
                }

                for (const car of cars) {
                    car.remainingTravelTime = car.hasArrived
                        ? 0
                        : Math.max(car.remainingTravelTime - DT, 0);
                }

                if (stepIndex % ETA_REFRESH_INTERVAL_STEPS === 0) {
                    recomputeTravelTimesByForecast();
                }

                snapshotTravelTimeField();
                snapshotDensityField();
                stepDirectMacro();
                e_d += computeTimestepDensityGapSq();
                l_d += computeOneStepLagrangianGapSq(null, lagMacroAdvanced);
            }

            function loop(timestamp) {
                if (lastTimestamp === null) lastTimestamp = timestamp;

                const elapsedRealSec = Math.max((timestamp - lastTimestamp) / 1000, 0);
                lastTimestamp = timestamp;

                if (!paused) {
                    accumulatedRealTime += elapsedRealSec * parseFloat(speedSlider.value);
                    accumulatedRealTime = Math.min(accumulatedRealTime, DT * MAX_STEPS_PER_FRAME);
                    while (!paused && accumulatedRealTime >= DT) {
                        stepSimulation();
                        accumulatedRealTime -= DT;
                    }
                }

                drawStage();
                for (const car of cars) car.draw();

                drawTfFieldStage();
                drawTfFieldAndScale();
                drawDensityFieldStage();
                drawDensityFieldAndScale();

                drawDirectMacroDensityStage();
                drawDirectMacroDensityAndScale();
                drawDirectMacroTravelTimeStage();
                drawDirectMacroTravelTimeAndScale();

                drawDensityLineComparison();
                drawTravelTimeLineComparison();

                const arrivedCount = wraparoundEnabled ? 0 : cumulativeArrived;
                const activeCount = cars.length;
                const totalCount = wraparoundEnabled
                    ? cars.length
                    : (simulationMode === MODE_ENDLESS ? cumulativeSpawned : initialPositions.length);

                const status = paused ? (t >= Tmax ? "paused at Tmax" : "all cars arrived") : "running";
                const mode = simulationMode === MODE_WRAP
                    ? "wraparound"
                    : (simulationMode === MODE_FINITE ? "finite-open" : "endless-random-open");

                // ne_d: mean squared density error per cell per timestep
                //   e_d sums over (Tmax/DT) steps × 2×200 cells (200 top + 200 bot, always).
                const ne_d = e_d * DT / Tmax / 400;

                // nl_d: 10-car normalised mean squared velocity error
                //   raw l_d = n_steps × 10 × DT² × <Δv²>, so divide by n_steps and DT²
                //   = l_d / (Tmax/DT) / DT² = l_d / (Tmax × DT)
                const nl_d = l_d / (Tmax * DT);

                hud.textContent =
                    `mode = ${mode} | status = ${status} | t = ${t.toFixed(1)} s / ${Tmax} s | dt = ${DT} s | cars active/arrived/total = ${activeCount}/${arrivedCount}/${totalCount} | min spacing = ${MIN_SPACING_M} m | l = ${l.toFixed(1)} m | T_F range: ${lastTfLegendRange.min.toFixed(1)}-${lastTfLegendRange.max.toFixed(1)} s | rho range: ${lastDensityRange.min.toFixed(3)}-${lastDensityRange.max.toFixed(3)} veh/m | e_d = ${e_d.toFixed(6)} | ne_d = ${ne_d.toExponential(3)} | l_d = ${l_d.toFixed(4)} | nl_d = ${nl_d.toFixed(4)}`;

                const edEl = document.getElementById("edDisplay");
                const edFinal = (t >= Tmax) ? "  [FINAL]" : "";
                edEl.innerHTML =
                    `e_d = ${e_d.toFixed(4)}  &nbsp; ne_d = ${ne_d.toExponential(3)} (veh/m)²/cell/step  <span style="font-size:12px;color:#aaa;">[mean sq. density err per cell per timestep]</span>${edFinal}<br>` +
                    `l_d = ${l_d.toFixed(4)} m²  &nbsp; nl_d = ${nl_d.toFixed(4)} (m/s)²  <span style="font-size:12px;color:#aaa;">[10-car mean sq. velocity err, independent of T/DT/N]</span>${edFinal}`;

                requestAnimationFrame(loop);
            }

            requestAnimationFrame(loop);
        </script>
    </body>
</html>
