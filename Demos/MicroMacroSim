                grad.addColorStop(1, tfColor(TF_COLOR_SCALE_MIN, TF_COLOR_SCALE_MIN, TF_COLOR_SCALE_MAX));
                tfCtx.fillStyle = grad;
                tfCtx.fillRect(legendX, legendY, legendW, legendH);
                tfCtx.strokeStyle = "#f0f0f0";
                tfCtx.lineWidth = 1;
                tfCtx.strokeRect(legendX, legendY, legendW, legendH);
                tfCtx.fillStyle = "#f0f0f0";
                tfCtx.font = "14px Arial";
                tfCtx.textAlign = "left";
                tfCtx.textBaseline = "bottom";
                tfCtx.fillText("T_F(t, x) scale", legendX, legendY - 6);
