                tfCtx.textAlign = "right";
                tfCtx.fillText(`Shorter ${TF_COLOR_SCALE_MIN.toFixed(1)} s`, legendX + legendW, legendY + legendH + 4);
            }

            function drawDensityFieldStage() {
